generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL") 
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String     @id @default(cuid())
  phone     String     @unique
  name      String
  password  String
  role      Role       @default(USER)
  properties Property[]
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  BUILDING
}

enum TransactionType {
  FOR_SALE
  FOR_RENT
}

model Property {
  id              String          @id @default(cuid())
  type            PropertyType
  transactionType TransactionType @default(FOR_SALE)
  price           Float
  location    String
  locationAr  String
  bedrooms    Int?
  bathrooms   Int?
  area        Float
  image       String       // Cloudinary URL
  images      String[]     // Additional Cloudinary Gallery URLs
  featured    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Admin Relation
  userId      String
  author      User         @relation(fields: [userId], references: [id])
  @@index([type])          // 🔥 filtre category rapide
  @@index([transactionType]) // 🔥 filtre vente/location rapide
  @@index([location])      // 🔥 search rapide
  @@index([createdAt])     // 🔥 pagination rapide
}
